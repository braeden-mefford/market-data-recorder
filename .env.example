# Copy this file to ".env" and fill in your own Kalshi values.
# The .env file is gitignored so your key never gets committed.

# Your Kalshi API key id (a uuid-looking string from the Kalshi site)
KALSHI_API_KEY_ID=your-api-key-id-here

# Full path to your RSA private key .pem file
KALSHI_PRIVATE_KEY_PATH=C:\path\to\your\kalshi_private_key.pem

# Which Kalshi series to capture (KXMLBGAME = MLB game winner markets)
KALSHI_SERIES=KXMLBGAME
